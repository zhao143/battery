<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bms.mapper.SysUserRoleMapper">
    
    <select id="selectAll" resultType="com.example.bms.domain.SysUserRole">
        SELECT * FROM sys_user_role
    </select>
    
    <select id="selectById" resultType="com.example.bms.domain.SysUserRole">
        SELECT * FROM sys_user_role WHERE id = #{id}
    </select>
    
    <insert id="insert" parameterType="com.example.bms.domain.SysUserRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user_role (user_id, role_id, created_at)
        VALUES (#{userId}, #{roleId}, #{createdAt})
    </insert>
    
    <delete id="delete">
        DELETE FROM sys_user_role WHERE id = #{id}
    </delete>
    
</mapper>
