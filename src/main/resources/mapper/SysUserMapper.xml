<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bms.mapper.SysUserMapper">

    <resultMap id="SysUserMap" type="com.example.bms.domain.SysUser">
        <id property="id" column="id" />
        <result property="username" column="username" />
        <result property="password" column="password" />
        <result property="nickname" column="nickname" />
        <result property="email" column="email" />
        <result property="phone" column="phone" />
        <result property="status" column="status" />
        <result property="createdAt" column="created_at" />
        <result property="updatedAt" column="updated_at" />
    </resultMap>

    <select id="selectById" resultMap="SysUserMap">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>

    <select id="selectByUsername" resultMap="SysUserMap">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <select id="selectByEmail" resultMap="SysUserMap">
        SELECT * FROM sys_user WHERE email = #{email}
    </select>

    <select id="selectByPhone" resultMap="SysUserMap">
        SELECT * FROM sys_user WHERE phone = #{phone}
    </select>

    <select id="selectAll" resultMap="SysUserMap">
        SELECT * FROM sys_user ORDER BY id
    </select>

    <insert id="insert" parameterType="com.example.bms.domain.SysUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user(username, password, nickname, email, phone, status, created_at, updated_at)
        VALUES(#{username}, #{password}, #{nickname}, #{email}, #{phone}, #{status}, #{createdAt}, #{updatedAt})
    </insert>

    <update id="update" parameterType="com.example.bms.domain.SysUser">
        UPDATE sys_user SET
            nickname = #{nickname},
            email = #{email},
            phone = #{phone},
            updated_at = #{updatedAt}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sys_user WHERE id = #{id}
    </delete>

    <insert id="insertUserRole">
        INSERT INTO sys_user_role(user_id, role_id) VALUES(#{userId}, #{roleId})
    </insert>

</mapper>